{
  "name": "dotfiles",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",

  "postCreateCommand": "bash -lc 'sudo apt-get update -qq && sudo apt-get install -y stow zsh fzf bat fd-find ripgrep neovim git && ./install.sh'",

  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.fontSize": 14,
        "editor.fontLigatures": true
      },
      "extensions": [
        "catppuccin.catppuccin-vsc",
        "EditorConfig.EditorConfig"
      ]
    }
  },

  "remoteEnv": {
    "DOTFILES": "${containerWorkspaceFolder}"
  }
}
