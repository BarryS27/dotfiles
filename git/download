[core]
	editor = nvim
	autocrlf = input
	excludesfile = ~/.gitignore_global
	pager = delta

[init]
	defaultBranch = main

# ── Fetch / Pull / Push ──────────────────
[fetch]
	prune = true       # auto-delete remote-tracking branches that no longer exist
	prunetags = true

[pull]
	rebase = true      # always rebase instead of merge on pull

[push]
	autoSetupRemote = true   # no need for -u origin on first push
	followTags = true         # push relevant tags along with commits

[rebase]
	autoStash = true    # stash/pop dirty worktree around rebase automatically
	autoSquash = true   # honour fixup!/squash! prefixes

# ── Merge / Diff ─────────────────────────
[merge]
	conflictstyle = zdiff3   # shows the base in conflicts — much clearer
	tool = nvimdiff

[mergetool "nvimdiff"]
	cmd = nvim -d $LOCAL $REMOTE $MERGED -c 'wincmd J'

[diff]
	algorithm = histogram     # fewer false conflicts on moved code
	colorMoved = default
	colorMovedWS = allow-indentation-change
	tool = nvimdiff

# ── Rerere ───────────────────────────────
[rerere]
	enabled = true      # remember and replay conflict resolutions
	autoupdate = true

# ── Sorting ──────────────────────────────
[branch]
	sort = -committerdate      # show most recently used branches first

[tag]
	sort = version:refname     # natural version sort: v1.9 before v1.10

# ── delta (diff pager) ───────────────────
[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	line-numbers = true
	side-by-side = false
	syntax-theme = Catppuccin Mocha
	file-style = bold yellow
	hunk-header-style = file line-number

# ── Aliases ──────────────────────────────
[alias]
	# Status & inspection
	st      = status -sb
	root    = rev-parse --show-toplevel

	# Branches
	sw      = switch
	co      = checkout
	br      = branch
	recent  = branch --sort=-committerdate --format='%(HEAD) %(color:yellow)%(refname:short)%(color:reset) %(color:green)%(committerdate:relative)%(color:reset) %(contents:subject)'

	# Commits
	cm      = commit
	amend   = commit --amend --no-edit
	wip     = "!git add -A && git commit -m 'wip'"
	unwip   = "!git log -1 --format='%s' | grep -q '^wip$' && git reset HEAD~1"
	undo    = reset HEAD~1 --mixed   # undo last commit, keep changes unstaged
	unstage = restore --staged

	# Log
	lg      = log --graph --decorate --pretty=format:'%C(yellow)%h%Creset %C(auto)%d%Creset %s %C(blue)%an, %ar%Creset' --abbrev-commit
	lga     = log --graph --decorate --pretty=format:'%C(yellow)%h%Creset %C(auto)%d%Creset %s %C(blue)%an, %ar%Creset' --abbrev-commit --all
	last    = log -1 HEAD --stat

	# Remote
	contributors = shortlog --summary --numbered --email

[color]
	ui = auto

# ── Machine-local overrides ───────────────
# ~/.gitconfig.local is not tracked — put work email, signing key, etc. there
[include]
	path = ~/.gitconfig.local
